rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    function isAuth() {
      return request.auth != null;
    }
    function isSuperAdmin() {
      return isAuth() && (
        request.auth.token.email == 'kimdh4790@gmail.com' ||
        request.auth.token.email == 'soungkyekim@naver.com'
      );
    }
    function isMyDealer(dealerId) {
      return isAuth() && (
        request.auth.uid == dealerId || isSuperAdmin()
      );
    }

    // ── 관제센터 서류 (사업자등록증·계약서) ──────────────────────
    match /companies/{dealerId}/{allPaths=**} {
      allow read: if isMyDealer(dealerId);
      allow write: if isMyDealer(dealerId);
    }

    // ── 정산·세금 문서 ─────────────────────────────────────────
    match /tax_docs/{dealerId}/{allPaths=**} {
      allow read, write: if isMyDealer(dealerId);
    }
    match /settlements/{dealerId}/{allPaths=**} {
      allow read, write: if isMyDealer(dealerId);
    }
    match /tax_invoices/{dealerId}/{allPaths=**} {
      allow read, write: if isMyDealer(dealerId);
    }
    match /stmt_kakao/{dealerId}/{allPaths=**} {
      allow read: if true;
      allow write: if isMyDealer(dealerId);
    }
    match /biz_docs/{userId}/{allPaths=**} {
      allow read, write: if isAuth() && (
        request.auth.uid == userId || isSuperAdmin()
      );
    }

    // ── FILO 메뉴 이미지 — 공개 읽기 (QR주문 페이지용) ──────────
    match /filo_menus/{dealerId}/{allPaths=**} {
      allow read: if true;
      allow write: if isMyDealer(dealerId);
    }

    // ── FILO 영수증·직원·예약 ────────────────────────────────────
    match /filo_receipts/{dealerId}/{allPaths=**} {
      allow read, write: if isMyDealer(dealerId);
    }
    match /receipts/{dealerId}/{allPaths=**} {
      allow read, write: if isMyDealer(dealerId);
    }
    match /staff_photos/{dealerId}/{allPaths=**} {
      allow read, write: if isMyDealer(dealerId);
    }

    // ── DINE 관련 ────────────────────────────────────────────────
    match /dine_schedule/{dealerId}/{allPaths=**} {
      allow read, write: if isMyDealer(dealerId);
    }
    match /dine_receipts/{dealerId}/{allPaths=**} {
      allow read, write: if isMyDealer(dealerId);
    }
    match /dine_cost_receipts/{dealerId}/{allPaths=**} {
      allow read, write: if isMyDealer(dealerId);
    }
    match /dine_staff_photos/{dealerId}/{allPaths=**} {
      allow read, write: if isMyDealer(dealerId);
    }

    // ── 회원·직원 ─────────────────────────────────────────────────
    match /members/{dealerId}/{allPaths=**} {
      allow read, write: if isMyDealer(dealerId);
    }

    // ── 공지 (슈퍼어드민만 쓰기) ─────────────────────────────────
    match /notices/{allPaths=**} {
      allow read: if isAuth();
      allow write: if isSuperAdmin();
    }

    // ── 슈퍼어드민 폴백 ──────────────────────────────────────────
    match /{allPaths=**} {
      allow read, write: if isSuperAdmin();
    }
  }
}
