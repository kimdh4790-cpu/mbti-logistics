rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    /* FILO 메뉴 이미지 - 로그인한 사용자 업로드, 누구나 읽기 */
    match /filo_menus/{dealerId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == dealerId;
    }
    /* 기타 파일 - 로그인 필요 */
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
