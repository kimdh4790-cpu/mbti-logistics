rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() { return request.auth != null; }
    function isOwner(did) { return isAuth() && (request.auth.uid == did || request.auth.token.dealerId == did); }
    function canRead() { return isAuth(); }
    function canWrite() { return isAuth(); }

    // ★ 테이블 주문용 공개 읽기
    match /filo_menus/{doc} {
      allow read: if true;
      allow write: if canWrite();
    }
    match /filo_tables/{doc} {
      allow read: if true;
      allow write: if canWrite();
    }
    match /filo_bookings/{doc} {
      allow read: if true;
      allow create: if true;
      allow update: if canWrite();
    }
    match /toss_orders/{doc} {
      allow read: if true;
      allow create: if true;
      allow update: if canWrite();
    }
    match /filo_table_orders/{doc} {
      allow read: if canRead();
      allow create: if true;
      allow write: if canWrite();
    }
    match /companies/{doc} {
      allow read: if true;
      allow write: if canWrite();
    }

    match /{document=**} {
      allow read: if canRead();
      allow write: if canWrite();
    }
  }
}
