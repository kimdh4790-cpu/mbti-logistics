rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ━━━ 기본 함수 ━━━
    function isAuth() {
      return request.auth != null;
    }
    function isSuperAdmin() {
      return isAuth() && (
        request.auth.token.email == 'kimdh4790@gmail.com' ||
        request.auth.token.email == 'soungkyekim@naver.com'
      );
    }
    function myUid() {
      return request.auth.uid;
    }
    function myDealerId() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.dealerId;
    }
    function isMyDealer(dealerId) {
      return isAuth() && (
        myUid() == dealerId ||
        myDealerId() == dealerId ||
        isSuperAdmin()
      );
    }
    function ownsDoc() {
      return isAuth() && (
        resource.data.dealerId == myUid() ||
        resource.data.dealerId == myDealerId() ||
        isSuperAdmin()
      );
    }
    function ownsNewDoc() {
      return isAuth() && (
        request.resource.data.dealerId == myUid() ||
        request.resource.data.dealerId == myDealerId() ||
        isSuperAdmin()
      );
    }
    // 공개 생성 허용 (고객 QR 예약 등)
    function ownsDocOrPublic() {
      return ownsDoc() || !isAuth();
    }

    // ━━━ 슈퍼어드민 전용 ━━━
    match /admins/{docId} {
      allow read: if isAuth();
      allow write: if isSuperAdmin();
    }
    match /security_logs/{docId} {
      allow read: if isSuperAdmin();
      allow create: if isAuth();
    }
    match /error_logs/{docId} {
      allow create: if isAuth();
      allow read: if isSuperAdmin();
    }
    match /admin_events/{docId} {
      allow read, write: if isSuperAdmin();
    }
    match /admin_notifications/{docId} {
      allow read, write: if isSuperAdmin();
    }
    match /cron_logs/{docId} {
      allow read: if isSuperAdmin();
      allow create: if false; // Worker에서만 생성
    }
    match /subscription_logs/{docId} {
      allow read: if isSuperAdmin();
      allow create: if isSuperAdmin();
    }

    // ━━━ 가입 신청 ━━━
    match /join_requests/{docId} {
      allow create: if true; // 누구나 신청 가능
      allow read, update, delete: if isSuperAdmin();
    }

    // ━━━ 알림톡 큐 ━━━
    match /alimtalk_queue/{docId} {
      allow create: if isAuth() || true; // Worker + 앱 모두
      allow read, update: if isSuperAdmin();
    }

    // ━━━ 회사 ━━━
    match /companies/{dealerId} {
      // read: 본인 회사만 (기존: 전체 공개 → 강화)
      allow read: if isAuth() && (
        isMyDealer(dealerId) || isSuperAdmin()
      );
      allow create: if isAuth();
      allow update: if isMyDealer(dealerId) || isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    // ━━━ 사용자 ━━━
    match /users/{userId} {
      allow read: if isAuth() && (
        myUid() == userId ||
        myDealerId() == resource.data.dealerId ||
        isSuperAdmin()
      );
      allow create: if isAuth();
      allow update, delete: if isAuth() && (
        myUid() == userId || isSuperAdmin()
      );
    }

    // ━━━ 구독/결제 ━━━
    match /subscriptions/{docId} {
      allow read: if ownsDoc() || isSuperAdmin();
      allow write: if isSuperAdmin();
    }
    match /payment_requests/{docId} {
      allow read: if ownsDoc();
      allow create: if ownsNewDoc();
      allow update, delete: if isSuperAdmin();
    }

    // ━━━ 핵심 정산 데이터 (dealerId 완전 격리) ━━━
    match /settlements/{docId} {
      allow read, write: if ownsDoc() || ownsNewDoc();
      allow create: if ownsNewDoc();
    }
    match /drivers/{docId} {
      allow read, write: if ownsDoc() || ownsNewDoc();
      allow create: if ownsNewDoc();
    }
    match /members/{docId} {
      allow read, write: if ownsDoc() || ownsNewDoc();
      allow create: if ownsNewDoc();
    }
    match /tax_docs/{docId} {
      allow read, write: if ownsDoc() || ownsNewDoc();
      allow create: if ownsNewDoc();
    }
    match /attendance/{docId} {
      allow read, write: if ownsDoc() || ownsNewDoc();
      allow create: if ownsNewDoc();
    }
    match /driver_settlements/{docId} {
      allow read, write: if ownsDoc() || ownsNewDoc();
    }
    match /hourly_settlements/{docId} {
      allow read, write: if ownsDoc() || ownsNewDoc();
    }
    match /contracts/{docId} {
      allow read, write: if ownsDoc() || ownsNewDoc();
    }
    match /leaves/{docId} {
      allow read, write: if ownsDoc() || ownsNewDoc();
    }
    match /overtimes/{docId} {
      allow read, write: if ownsDoc() || ownsNewDoc();
    }
    match /evaluations/{docId} {
      allow read, write: if ownsDoc() || ownsNewDoc();
    }
    match /notices/{docId} {
      allow read, write: if ownsDoc() || ownsNewDoc();
    }
    match /payout_sessions/{docId} {
      allow read, write: if ownsDoc() || ownsNewDoc();
    }
    match /ind_workers/{docId} {
      allow read, write: if ownsDoc() || ownsNewDoc();
    }
    match /settings/{docId} {
      allow read, write: if ownsDoc() || ownsNewDoc();
    }
    match /cal_memos/{docId} {
      allow read, write: if ownsDoc() || ownsNewDoc();
    }
    match /roster_week/{docId} {
      allow read, write: if ownsDoc() || ownsNewDoc();
    }
    match /vehicles/{docId} {
      allow read, write: if ownsDoc() || ownsNewDoc();
    }
    match /expenses/{docId} {
      allow read, write: if ownsDoc() || ownsNewDoc();
    }
    match /documents/{docId} {
      allow read, write: if ownsDoc() || ownsNewDoc();
    }
    match /delivery_sessions/{docId} {
      allow read, write: if ownsDoc() || ownsNewDoc();
    }
    match /dispatch_results/{docId} {
      allow read, write: if ownsDoc() || ownsNewDoc();
    }
    match /driver_notifications/{docId} {
      allow read, write: if ownsDoc() || ownsNewDoc();
    }
    match /devices/{docId} {
      allow read, write: if ownsDoc() || ownsNewDoc();
    }
    match /clean_orders/{docId} {
      allow read, write: if ownsDoc() || ownsNewDoc();
    }
    match /clean_workers/{docId} {
      allow read, write: if ownsDoc() || ownsNewDoc();
    }

    // ━━━ 재고관리 (dealerId 완전 격리) ━━━
    match /inventory/{docId} {
      allow read, write: if ownsDoc() || ownsNewDoc();
      allow create: if ownsNewDoc();
    }
    match /inventory_in/{docId} {
      allow read, write: if ownsDoc() || ownsNewDoc();
      allow create: if ownsNewDoc();
    }
    match /inventory_out/{docId} {
      allow read, write: if ownsDoc() || ownsNewDoc();
      allow create: if ownsNewDoc();
    }
    match /inv_edit_log/{docId} {
      allow read, write: if ownsDoc() || ownsNewDoc();
    }

    // ━━━ mbetco (키오스크·QR·예약) dealerId 격리 ━━━
    match /mbetco_bookings/{docId} {
      // 고객이 예약 생성 가능 (비로그인)
      allow create: if true;
      allow read, update: if ownsDoc() || isSuperAdmin();
      allow delete: if ownsDoc() || isSuperAdmin();
    }
    match /mbetco_sales/{docId} {
      allow read, write: if ownsDoc() || ownsNewDoc();
      allow create: if ownsNewDoc();
    }
    match /mbetco_customers/{docId} {
      allow read, write: if ownsDoc() || ownsNewDoc();
      allow create: if true; // 고객 자동 등록
    }
    match /mbetco_services/{docId} {
      allow read: if true; // 고객이 서비스 목록 조회
      allow write: if ownsDoc() || ownsNewDoc();
      allow create: if ownsNewDoc();
    }
    match /mbetco_reviews/{docId} {
      allow create: if true; // 고객이 리뷰 작성
      allow read: if true;
      allow update, delete: if ownsDoc() || isSuperAdmin();
    }
    match /mbetco_coupons/{docId} {
      allow read: if true; // 고객이 쿠폰 확인
      allow write: if ownsDoc() || ownsNewDoc();
    }
    match /mbetco_mappings/{docId} {
      allow read, write: if ownsDoc() || ownsNewDoc();
    }
    match /mbetco_settles/{docId} {
      allow read, write: if ownsDoc() || ownsNewDoc();
    }
    match /mbetco_workers/{docId} {
      allow read, write: if ownsDoc() || ownsNewDoc();
    }

    // ━━━ beauty_sales (키오스크 매출) ━━━
    match /beauty_sales/{docId} {
      allow read, write: if ownsDoc() || ownsNewDoc();
      allow create: if ownsNewDoc();
    }

    // ━━━ 세무사 공유 (토큰 기반) ━━━
    match /taxShares/{docId} {
      allow read: if true;
      allow write: if isAuth();
      match /settlements/{sId} {
        allow read: if true;
        allow write: if isAuth();
      }
    }

    // ━━━ 방문자/고객 공개 ━━━
    match /visitors/{docId} {
      allow create: if true;
      allow read, write: if isAuth();
    }
    match /open_event/{docId} {
      allow read: if true;
      allow write: if isAuth();
    }

    // ━━━ 나머지 미분류 (로그인 필요) ━━━
    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }
  }
}
