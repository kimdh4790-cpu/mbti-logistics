rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── 기본 인증 헬퍼 ─────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }
    function isSuperAdmin() {
      return isAuth() && (
        request.auth.token.email == 'kimdh4790@gmail.com' ||
        request.auth.token.email == 'soungkyekim@naver.com'
      );
    }
    function myUid() {
      return request.auth.uid;
    }
    function myDealerId() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.dealerId;
    }
    function isMyDealer(dealerId) {
      return isAuth() && (
        myUid() == dealerId ||
        myDealerId() == dealerId ||
        isSuperAdmin()
      );
    }
    function ownsDoc() {
      return isAuth() && (
        resource.data.dealerId == myUid() ||
        resource.data.dealerId == myDealerId() ||
        isSuperAdmin()
      );
    }
    function ownsNewDoc() {
      return isAuth() && (
        request.resource.data.dealerId == myUid() ||
        request.resource.data.dealerId == myDealerId() ||
        isSuperAdmin()
      );
    }

    // ── 관리/로그/시스템 ──────────────────────────────────────
    match /admins/{docId} {
      allow read: if isAuth();
      allow write: if isSuperAdmin();
    }
    match /security_logs/{docId} {
      allow read: if isSuperAdmin();
      allow create: if isAuth();
    }
    match /error_logs/{docId} {
      allow create: if isAuth();
      allow read: if isSuperAdmin();
    }
    match /admin_events/{docId} {
      allow read, write: if isSuperAdmin();
    }
    match /admin_notifications/{docId} {
      allow read, write: if isSuperAdmin();
    }
    match /admin_tokens/{docId} {
      // FCM 토큰 등록용 — 본인 토큰만 쓰기 허용
      allow read: if isAuth() && resource.data.uid == myUid() || isSuperAdmin();
      allow write: if isAuth();
    }
    match /cron_logs/{docId} {
      allow read: if isSuperAdmin();
      allow create: if false; // Worker 서버사이드에서만 작성
    }
    match /subscription_logs/{docId} {
      allow read, write: if isSuperAdmin();
    }
    match /alimtalk_queue/{docId} {
      allow create: if isAuth();
      allow read, update: if isSuperAdmin();
    }
    match /join_requests/{docId} {
      allow create: if true; // 비로그인 신청 허용
      allow read, update, delete: if isSuperAdmin();
    }

    // ── 회사/사용자 ────────────────────────────────────────────
    match /companies/{dealerId} {
      allow read: if isAuth() && (
        isMyDealer(dealerId) || isSuperAdmin()
      );
      allow create: if isAuth();
      allow update: if isMyDealer(dealerId) || isSuperAdmin();
      allow delete: if isSuperAdmin();
    }
    match /users/{userId} {
      allow read: if isAuth() && (
        myUid() == userId ||
        myDealerId() == resource.data.dealerId ||
        isSuperAdmin()
      );
      allow create: if isAuth();
      allow update, delete: if isAuth() && (
        myUid() == userId || isSuperAdmin()
      );
    }

    // ── 구독/결제 ─────────────────────────────────────────────
    // subscriptions: 클라이언트 읽기 허용 (subscribe.html에서 직접 체크)
    // 쓰기는 Worker(서버사이드)에서만 → 클라이언트 write 차단
    match /subscriptions/{docId} {
      allow read: if isAuth() && (
        docId == myUid() || isSuperAdmin()
      );
      allow write: if isSuperAdmin(); // Worker는 Admin SDK → rules 우회
    }
    // payments: 본인 결제내역 읽기 + 슈퍼어드민 전체
    match /payments/{docId} {
      allow read: if isAuth() && (
        resource.data.dealerId == myUid() ||
        resource.data.dealerId == myDealerId() ||
        isSuperAdmin()
      );
      allow create: if false; // Worker에서만 생성
      allow update, delete: if isSuperAdmin();
    }
    match /payment_requests/{docId} {
      allow read: if ownsDoc();
      allow create: if ownsNewDoc();
      allow update, delete: if isSuperAdmin();
    }
    match /plan_guards/{docId} {
      allow read, write: if ownsDoc() || ownsNewDoc();
    }
    match /plan_guard_alerts/{docId} {
      allow read, write: if ownsDoc() || ownsNewDoc();
    }

    // ── 정산/배송/근태 ────────────────────────────────────────
    match /settlements/{docId} {
      allow read, write: if ownsDoc() || ownsNewDoc();
    }
    match /drivers/{docId} {
      allow read, write: if ownsDoc() || ownsNewDoc();
    }
    match /members/{docId} {
      allow read, write: if ownsDoc() || ownsNewDoc();
    }
    match /tax_docs/{docId} {
      allow read, write: if ownsDoc() || ownsNewDoc();
    }
    match /attendance/{docId} {
      allow read, write: if ownsDoc() || ownsNewDoc();
    }
    match /driver_settlements/{docId} {
      allow read, write: if ownsDoc() || ownsNewDoc();
    }
    match /delivery_sessions/{docId} {
      allow read, write: if ownsDoc() || ownsNewDoc();
    }
    match /dispatch_results/{docId} {
      allow read, write: if ownsDoc() || ownsNewDoc();
    }
    match /hourly_settlements/{docId} {
      allow read, write: if ownsDoc() || ownsNewDoc();
    }
    match /contracts/{docId} {
      allow read, write: if ownsDoc() || ownsNewDoc();
    }
    match /leaves/{docId} {
      allow read, write: if ownsDoc() || ownsNewDoc();
    }
    match /absences/{docId} {
      allow read, write: if ownsDoc() || ownsNewDoc();
    }
    match /leave_payments/{docId} {
      allow read, write: if ownsDoc() || ownsNewDoc();
    }
    match /overtimes/{docId} {
      allow read, write: if ownsDoc() || ownsNewDoc();
    }
    match /evaluations/{docId} {
      allow read, write: if ownsDoc() || ownsNewDoc();
    }
    match /notices/{docId} {
      allow read, write: if ownsDoc() || ownsNewDoc();
    }
    match /driver_notifications/{docId} {
      allow read, write: if ownsDoc() || ownsNewDoc();
    }
    match /devices/{docId} {
      allow read, write: if ownsDoc() || ownsNewDoc();
    }
    match /biometrics/{docId} {
      allow read, write: if ownsDoc() || ownsNewDoc();
    }
    match /lunch/{docId} {
      allow read, write: if ownsDoc() || ownsNewDoc();
    }
    match /lunch_alerts/{docId} {
      allow read, write: if ownsDoc() || ownsNewDoc();
    }
    match /roster_week/{docId} {
      allow read, write: if ownsDoc() || ownsNewDoc();
    }
    match /vehicles/{docId} {
      allow read, write: if ownsDoc() || ownsNewDoc();
    }
    match /maintenance/{docId} {
      allow read, write: if ownsDoc() || ownsNewDoc();
    }
    match /expenses/{docId} {
      allow read, write: if ownsDoc() || ownsNewDoc();
    }
    match /documents/{docId} {
      allow read, write: if ownsDoc() || ownsNewDoc();
    }
    match /signatures/{docId} {
      allow read, write: if ownsDoc() || ownsNewDoc();
    }
    match /driverDocs/{docId} {
      allow read, write: if ownsDoc() || ownsNewDoc();
    }
    match /ind_workers/{docId} {
      allow read, write: if ownsDoc() || ownsNewDoc();
    }
    match /payout_sessions/{docId} {
      allow read, write: if ownsDoc() || ownsNewDoc();
    }
    match /settings/{docId} {
      allow read, write: if ownsDoc() || ownsNewDoc();
    }
    match /cal_memos/{docId} {
      allow read, write: if ownsDoc() || ownsNewDoc();
    }
    match /idSupport/{docId} {
      allow read, write: if ownsDoc() || ownsNewDoc();
    }

    // ── 청소/위탁 ────────────────────────────────────────────
    match /clean_orders/{docId} {
      allow read, write: if ownsDoc() || ownsNewDoc();
    }
    match /clean_dispatch/{docId} {
      allow read, write: if ownsDoc() || ownsNewDoc();
    }
    match /clean_workers/{docId} {
      allow read, write: if ownsDoc() || ownsNewDoc();
    }

    // ── 재고관리 (mbtico) ─────────────────────────────────────
    match /inventory/{docId} {
      allow read, write: if ownsDoc() || ownsNewDoc();
    }
    match /inventory_in/{docId} {
      allow read, write: if ownsDoc() || ownsNewDoc();
    }
    match /inventory_out/{docId} {
      allow read, write: if ownsDoc() || ownsNewDoc();
    }
    match /inv_edit_log/{docId} {
      allow read, write: if ownsDoc() || ownsNewDoc();
    }
    match /inv_change_log/{docId} {
      allow read, write: if ownsDoc() || ownsNewDoc();
    }

    // ── mbtico 공통 (예약·매출·고객·서비스·리뷰·쿠폰) ─────────
    match /mbetco_bookings/{docId} {
      allow create: if true; // 고객 예약 비로그인 허용
      allow read, update, delete: if ownsDoc() || isSuperAdmin();
    }
    match /mbetco_sales/{docId} {
      allow read, write: if ownsDoc() || ownsNewDoc();
    }
    match /mbetco_customers/{docId} {
      allow create: if true; // 고객 자기등록 허용
      allow read, write: if ownsDoc() || ownsNewDoc();
    }
    match /mbetco_services/{docId} {
      allow read: if true; // QR 결제 페이지에서 비로그인 조회
      allow write: if ownsDoc() || ownsNewDoc();
    }
    match /mbetco_reviews/{docId} {
      allow create, read: if true; // 고객 리뷰 등록·조회
      allow update, delete: if ownsDoc() || isSuperAdmin();
    }
    match /mbetco_coupons/{docId} {
      allow read: if true;
      allow write: if ownsDoc() || ownsNewDoc();
    }
    match /mbetco_mappings/{docId} {
      allow read, write: if ownsDoc() || ownsNewDoc();
    }
    match /mbetco_settles/{docId} {
      allow read, write: if ownsDoc() || ownsNewDoc();
    }
    match /mbetco_settle_details/{docId} {
      allow read, write: if ownsDoc() || ownsNewDoc();
    }
    match /mbetco_workers/{docId} {
      allow read, write: if ownsDoc() || ownsNewDoc();
    }
    match /mbetco_companies/{docId} {
      allow read: if isAuth() && (
        resource.data.email == request.auth.token.email || isSuperAdmin()
      );
      allow create: if isSuperAdmin();
      allow update, delete: if isSuperAdmin();
    }
    match /beauty_sales/{docId} {
      allow read, write: if ownsDoc() || ownsNewDoc();
    }

    // ── 세금/공유 ────────────────────────────────────────────
    match /taxShares/{docId} {
      allow read: if true;
      allow write: if isAuth();
      match /settlements/{sId} {
        allow read: if true;
        allow write: if isAuth();
      }
    }

    // ── 방문자/고객프로필 ─────────────────────────────────────
    match /visitors/{docId} {
      allow create: if true;
      allow read, write: if isAuth();
    }
    match /customer_profiles/{docId} {
      allow create: if true;
      allow read, write: if isAuth();
    }
    match /customer_invites/{docId} {
      allow read, write: if isAuth();
    }
    match /customer_notifications/{docId} {
      allow read, write: if isAuth();
    }
    match /customer_push_queue/{docId} {
      allow read, write: if isAuth();
    }
    match /sms_queue/{docId} {
      allow read, write: if isAuth();
    }
    match /open_event/{docId} {
      allow read: if true;
      allow write: if isAuth();
    }

    // ── 폴백: 슈퍼어드민 전체 접근 ───────────────────────────
    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }
  }
}
